---
const {
  title = 'Tim Chen · AI 时代网志',
  description = 'AI 时代的个人网志 — 博客、快讯与思考。',
  canonical,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonicalUrl = canonical ? new URL(canonical, Astro.site ?? 'https://chenyuqing.github.io').toString() : undefined;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!doctype html>
<html lang="zh-CN" data-lang="zh" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script define:vars={{ gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', gaMeasurementId, {
            anonymize_ip: true,
          });
        </script>
      </>
    )}
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storedLang = localStorage.getItem('site-lang');
        const storedTheme = localStorage.getItem('site-theme');
        const lang = storedLang === 'en' ? 'en' : 'zh';
        const theme = storedTheme === 'dark'
          ? 'dark'
          : storedTheme === 'light'
            ? 'light'
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        root.setAttribute('data-lang', lang);
        root.setAttribute('data-theme', theme);
        root.setAttribute('lang', lang === 'en' ? 'en' : 'zh-CN');
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content" data-i18n="skip_to_content">跳到内容</a>
    <header class="site-header" id="site-header">
      <div class="shell header-row">
        <a class="brand" href="/" aria-label="返回首页">
          <span class="brand-mark">
            <img src="/favicon-64x64.png" alt="Tim Chen avatar" />
          </span>
          <span class="brand-text">
            <strong>Tim Chen</strong>
            <small>creator lab</small>
          </span>
        </a>
        <div class="header-actions">
          <nav class="site-nav" aria-label="Primary">
            <a class="nav-pill" href="/" aria-current={pathname === '/' ? 'page' : undefined} data-i18n="nav_home">首页</a>
            <div class="nav-dropdown" id="nav-content-dropdown">
              <button class="nav-pill nav-dropdown-trigger" type="button" aria-expanded="false" data-i18n="nav_content">内容 ▾</button>
              <div class="nav-dropdown-menu">
                <div class="nav-dropdown-col">
                  <a class="nav-dropdown-item" href="/news/">
                    <span class="nav-dropdown-kicker" data-i18n="nav_news">AI新闻</span>
                    <span class="nav-dropdown-desc" data-i18n="nav_news_desc">看最新模型、产品发布与 AI 领域动态</span>
                  </a>
                  <a class="nav-dropdown-item" href="/blog/">
                    <span class="nav-dropdown-kicker" data-i18n="nav_blog">播客</span>
                    <span class="nav-dropdown-desc" data-i18n="nav_blog_desc">读长文内容，关注工作流、产品与实践</span>
                  </a>
                </div>
                <div class="nav-dropdown-col nav-dropdown-col-secondary">
                  <a class="nav-dropdown-item" href="/about/">
                    <span class="nav-dropdown-kicker" data-i18n="nav_about">关于</span>
                    <span class="nav-dropdown-desc" data-i18n="nav_about_desc">了解我在做什么，以及这个站点的方向</span>
                  </a>
                  <a class="nav-dropdown-item" href="https://github.com/chenyuqing" target="_blank" rel="noreferrer">
                    <span class="nav-dropdown-kicker" data-i18n="nav_github">GitHub</span>
                    <span class="nav-dropdown-desc" data-i18n="nav_github_desc">查看代码、项目与公开实验记录</span>
                  </a>
                </div>
              </div>
            </div>
          </nav>
          <div class="site-controls">
            <button
              id="lang-toggle"
              class="nav-pill toggle-pill"
              type="button"
              data-i18n-aria-label="toggle_lang_aria"
              data-i18n="toggle_lang_button"
            >
              中 / EN
            </button>
            <button
              id="theme-toggle"
              class="nav-pill toggle-pill"
              type="button"
              data-i18n-aria-label="toggle_theme_aria"
              data-i18n="theme_light_label"
            >
              浅色模式
            </button>
          </div>
        </div>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="shell footer-panel">
        <div class="footer-top">
          <div class="footer-brand-block">
            <p class="footer-kicker" data-i18n="footer_kicker">Tim Chen</p>
            <h2 class="footer-title" data-i18n="footer_title">AI 时代的内容入口</h2>
            <p class="footer-desc" data-i18n="footer_desc">围绕 AI 新闻、播客文章、工具实验与创作工作流，持续更新一个更像媒体而不是旧式博客的个人站点。</p>
          </div>

          <div class="footer-grid">
            <div class="footer-col">
              <p class="footer-col-title" data-i18n="footer_col_content">内容</p>
              <a href="/news/" data-i18n="footer_news">AI新闻</a>
              <a href="/blog/" data-i18n="footer_blog">播客</a>
              <a href="/rss.xml">RSS</a>
            </div>

            <div class="footer-col">
              <p class="footer-col-title" data-i18n="footer_col_site">站点</p>
              <a href="/" data-i18n="footer_home">首页</a>
              <a href="/about/" data-i18n="footer_about">关于</a>
              <button class="footer-inline-btn" type="button" id="footer-ai-trigger" data-i18n="footer_ai">AI 问答</button>
            </div>

            <div class="footer-col">
              <p class="footer-col-title" data-i18n="footer_col_elsewhere">其他</p>
              <a href="https://github.com/chenyuqing" target="_blank" rel="noreferrer">GitHub</a>
              <a href="mailto:tim@dwyx.xyz" data-i18n="footer_email">邮箱</a>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <p data-i18n="footer_copy">2026 © Tim Chen · AI Creator Playground</p>
          <p data-i18n="footer_note">Built with Astro. Edited for the AI era.</p>
        </div>
      </div>
    </footer>
