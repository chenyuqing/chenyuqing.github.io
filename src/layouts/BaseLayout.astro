    <script is:inline>
    (() => {
      const fab = document.getElementById('ai-agent-btn');
      const panel = document.getElementById('ai-agent-panel');
      const closeBtn = document.getElementById('ai-panel-close');
      const settingsToggle = document.getElementById('ai-settings-toggle');
      const settingsBody = document.getElementById('ai-settings-body');
      const settingsPanel = document.getElementById('ai-settings');
      const settingsSummary = document.getElementById('ai-settings-summary');
      const providerSelect = document.getElementById('ai-provider');
      const baseUrlRow = document.getElementById('ai-base-url-row');
      const baseUrlInput = document.getElementById('ai-base-url');
      const modelInput = document.getElementById('ai-model');
      const apiKeyInput = document.getElementById('ai-api-key');
      const saveSettingsBtn = document.getElementById('ai-save-settings');
      const resetSettingsBtn = document.getElementById('ai-reset-settings');
      const testConnectionBtn = document.getElementById('ai-test-connection');
      const testStatusEl = document.getElementById('ai-test-status');
      const providerNote = document.getElementById('ai-provider-note');
      const messagesEl = document.getElementById('ai-messages');
      const form = document.getElementById('ai-form');
      const input = document.getElementById('ai-input');
      const introAiTrigger = document.getElementById('intro-ai-trigger');
      const footerAiTrigger = document.getElementById('footer-ai-trigger');
      const aiUiLang = document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
      const providerNotes = {
        zh: {
          compatible: '浏览器直连需要目标服务支持 CORS。OpenAI / Claude 官方接口请通过你自己的代理转发。',
          openai: 'OpenAI 官方接口不能安全地从这个静态站直连。请填写你自己的 OpenAI 代理 Base URL。',
          claude: 'Claude 官方接口不能安全地从这个静态站直连。请填写你自己的 Claude 代理 Base URL。',
        },
        en: {
          compatible: 'Direct browser calls require a provider that supports CORS. Use your own proxy for official OpenAI or Claude APIs.',
          openai: 'Official OpenAI endpoints should not be called directly from this static site. Enter your own OpenAI proxy base URL.',
          claude: 'Official Claude endpoints should not be called directly from this static site. Enter your own Claude proxy base URL.',
        },
      };

      const STORAGE_KEY = 'ai-agent-config-v1';

      const navDropdowns = [
        document.getElementById('nav-content-dropdown'),
        document.getElementById('nav-settings-dropdown'),
      ].filter(Boolean);

      const closeNavDropdown = (dropdown) => {
        if (!dropdown) return;
        dropdown.classList.remove('dropdown-open');
        dropdown.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      };

      const openNavDropdown = (dropdown) => {
        navDropdowns.forEach((item) => {
          if (item !== dropdown) closeNavDropdown(item);
        });
        dropdown.classList.add('dropdown-open');
        dropdown.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'true');
      };

      const toggleNavDropdown = (dropdown) => {
        if (!dropdown) return;
        if (dropdown.classList.contains('dropdown-open')) {
          closeNavDropdown(dropdown);
        } else {
          openNavDropdown(dropdown);
        }
      };

      const updateSettingsSummary = () => {
        if (!settingsSummary) return;
        const providerLabel = providerSelect?.selectedOptions?.[0]?.textContent?.trim() || 'OpenAI Compatible';
        const modelLabel = modelInput?.value?.trim() || 'gpt-4o-mini';
        const baseUrl = baseUrlInput?.value?.trim();
        let hostLabel = 'no base url';
        if (baseUrl) {
          try {
            hostLabel = new URL(baseUrl).host;
          } catch {
            hostLabel = baseUrl.replace(/^https?:\/\//, '').split('/')[0] || baseUrl;
          }
        }
        settingsSummary.textContent = `${providerLabel} · ${modelLabel} · ${hostLabel}`;
      };

      const messages = {
        zh: {
          testing: '正在测试连接...',
          missingApiKey: '请先填写 API Key。',
          missingBaseUrlCompatible: '请先填写支持浏览器直连的 Base URL。',
          missingBaseUrlProxy: '请先填写你自己的代理 Base URL。',
          success: '连接成功，可以开始提问了。',
          blocked: '浏览器网络请求失败。请检查 CORS、浏览器插件或代理地址。',
          unknownError: '连接失败：',
          saved: '已保存到当前浏览器。',
          reset: '已清空当前浏览器中的设置。',
          copy: '复制',
          copied: '已复制',
          copyFailed: '复制失败',
        },
        en: {
          testing: 'Testing connection...',
          missingApiKey: 'Please enter an API key first.',
          missingBaseUrlCompatible: 'Please enter a browser-accessible Base URL first.',
          missingBaseUrlProxy: 'Please enter your proxy Base URL first.',
          success: 'Connection OK. You can start asking questions.',
          blocked: 'Browser network request failed. Check CORS, browser extensions, or the proxy URL.',
          unknownError: 'Connection failed: ',
          saved: 'Saved to this browser.',
          reset: 'Settings cleared from this browser.',
          copy: 'Copy',
          copied: 'Copied',
          copyFailed: 'Copy failed',
        },
      };

      const loadConfig = () => {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return;
          const c = JSON.parse(raw);
          if (c.provider) providerSelect.value = c.provider;
          if (c.baseUrl) baseUrlInput.value = c.baseUrl;
          if (c.model) modelInput.value = c.model;
          if (c.apiKey) apiKeyInput.value = c.apiKey;
        } catch {}
        providerSelect.dispatchEvent(new Event('change'));
      };

      const saveConfig = () => {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          provider: providerSelect.value,
          baseUrl: baseUrlInput.value,
          model: modelInput.value,
          apiKey: apiKeyInput.value,
        }));
      };

      fab?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', panel.getAttribute('aria-hidden') === 'true' ? 'false' : 'true');
      });

      introAiTrigger?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', 'false');
        input?.focus();
      });

      footerAiTrigger?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', 'false');
        input?.focus();
      });

      closeBtn?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', 'true');
      });

      settingsToggle?.addEventListener('click', () => {
        const nextOpen = settingsBody.hidden;
        settingsBody.hidden = !nextOpen;
        settingsBody.style.display = nextOpen ? 'grid' : 'none';
        settingsPanel?.classList.toggle('is-open', nextOpen);
        settingsToggle.setAttribute('aria-expanded', String(nextOpen));
      });

      providerSelect?.addEventListener('change', () => {
        const v = providerSelect.value;
        baseUrlRow.hidden = false;
        if (v === 'openai') {
          modelInput.placeholder = modelInput.value = 'gpt-4o-mini';
          baseUrlInput.placeholder = 'https://your-proxy.example.com/v1';
          providerNote.textContent = providerNotes[aiUiLang].openai;
        } else if (v === 'claude') {
          modelInput.placeholder = modelInput.value = 'claude-sonnet-4-20250514';
          baseUrlInput.placeholder = 'https://your-proxy.example.com/v1';
          providerNote.textContent = providerNotes[aiUiLang].claude;
        } else {
          modelInput.placeholder = 'deepseek-chat';
          if (!modelInput.value) modelInput.value = 'deepseek-chat';
          baseUrlInput.placeholder = 'https://api.example.com/v1';
          providerNote.textContent = providerNotes[aiUiLang].compatible;
        }
        updateSettingsSummary();
        saveConfig();
      });

      [baseUrlInput, modelInput, apiKeyInput].forEach(el => {
        el?.addEventListener('change', () => {
          updateSettingsSummary();
          saveConfig();
        });
      });

      loadConfig();
      updateSettingsSummary();
      if (settingsBody?.hidden) settingsBody.style.display = 'none';

      const getEndpoint = () => {
        const p = providerSelect.value;
        const base = baseUrlInput.value.replace(/\/+$/, '');
        if (p === 'openai') return base + '/chat/completions';
        if (p === 'claude') return base + '/messages';
        return base + '/chat/completions';
      };

      const getHeaders = () => {
        const p = providerSelect.value;
        const key = apiKeyInput.value;
        if (p === 'claude') return {
          'Content-Type': 'application/json',
          'x-api-key': key,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true',
        };
        return {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + key,
        };
      };

      const buildBody = (messages) => {
        const p = providerSelect.value;
        const model = modelInput.value;
        if (p === 'claude') return JSON.stringify({
          model,
          max_tokens: 1024,
          messages,
        });
        return JSON.stringify({ model, messages, max_tokens: 1024 });
      };

      const addMsg = (role, text) => {
        const div = document.createElement('div');
        div.className = 'ai-msg ai-msg-' + role;

        const body = document.createElement('div');
        body.className = 'ai-msg-body';
        body.textContent = text;
        div.appendChild(body);

        if (role === 'assistant' || role === 'error') {
          const copy = messages[aiUiLang];
          const copyBtn = document.createElement('button');
          copyBtn.type = 'button';
          copyBtn.className = 'ai-msg-copy';
          copyBtn.textContent = copy.copy;
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(text);
              copyBtn.textContent = copy.copied;
            } catch {
              copyBtn.textContent = copy.copyFailed;
            }
            window.setTimeout(() => {
              copyBtn.textContent = copy.copy;
            }, 1200);
          });
          div.appendChild(copyBtn);
        }

        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      };

      const addSourcesMsg = (results) => {
        if (!results.length) return;

        const div = document.createElement('div');
        div.className = 'ai-msg ai-msg-sources';

        const title = document.createElement('div');
        title.className = 'ai-sources-title';
        title.textContent = aiUiLang === 'en' ? 'Matched Sources' : '命中来源';
        div.appendChild(title);

        const list = document.createElement('div');
        list.className = 'ai-sources-list';

        results.forEach((result) => {
          const item = document.createElement('a');
          item.className = 'ai-source-item';
          item.href = result._type === 'news' ? `/news/${result.id}/` : `/blog/${result.id}/`;

          const meta = document.createElement('div');
          meta.className = 'ai-source-meta';
          meta.textContent = `${result._type === 'news' ? 'News' : 'Blog'} · ${result.pubDate}`;

          const heading = document.createElement('div');
          heading.className = 'ai-source-title';
          heading.textContent = result.title;

          const desc = document.createElement('div');
          desc.className = 'ai-source-desc';
          desc.textContent = result.description || (result.body || '').slice(0, 90);

          item.appendChild(meta);
          item.appendChild(heading);
          item.appendChild(desc);
          list.appendChild(item);
        });

        div.appendChild(list);
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      };

      const setTestStatus = (type, text) => {
        if (!testStatusEl) return;
        testStatusEl.className = 'ai-test-status ai-test-status-' + type;
        testStatusEl.textContent = text;
      };

      saveSettingsBtn?.addEventListener('click', () => {
        saveConfig();
        updateSettingsSummary();
        setTestStatus('success', messages[aiUiLang].saved);
      });

      resetSettingsBtn?.addEventListener('click', () => {
        localStorage.removeItem(STORAGE_KEY);
        providerSelect.value = 'compatible';
        baseUrlInput.value = '';
        modelInput.value = 'gpt-4o-mini';
        apiKeyInput.value = '';
        providerSelect.dispatchEvent(new Event('change'));
        updateSettingsSummary();
        setTestStatus('success', messages[aiUiLang].reset);
      });

      const extractErrorMessage = async (res) => {
        const text = await res.text();
        try {
          const json = JSON.parse(text);
          return json?.error?.message || json?.error || json?.message || text;
        } catch {
          return text;
        }
      };

      testConnectionBtn?.addEventListener('click', async () => {
        const copy = messages[aiUiLang];
        if (!apiKeyInput.value.trim()) {
          setTestStatus('error', copy.missingApiKey);
          return;
        }
        if (!baseUrlInput.value.trim()) {
          setTestStatus('error', providerSelect.value === 'compatible' ? copy.missingBaseUrlCompatible : copy.missingBaseUrlProxy);
          return;
        }

        testConnectionBtn.disabled = true;
        setTestStatus('loading', copy.testing);

        const p = providerSelect.value;
        const testMessages = p === 'claude'
          ? [{ role: 'user', content: 'Reply with OK.' }]
          : [{ role: 'user', content: 'Reply with OK.' }];

        try {
          const res = await fetch(getEndpoint(), {
            method: 'POST',
            headers: getHeaders(),
            body: buildBody(testMessages),
          });

          if (!res.ok) {
            const message = await extractErrorMessage(res);
            setTestStatus('error', `${res.status}: ${message.slice(0, 180)}`);
            return;
          }

          setTestStatus('success', copy.success);
        } catch (err) {
          const message = err?.message || String(err);
          if (/Failed to fetch|NetworkError|Load failed/i.test(message)) {
            setTestStatus('error', copy.blocked);
            return;
          }
          setTestStatus('error', copy.unknownError + message);
        } finally {
          testConnectionBtn.disabled = false;
        }
      });

      let siteIndexCache = null;

      const loadSiteIndex = async (question) => {
        if (siteIndexCache) return siteIndexCache;
        const isRecent = /最近|近期|latest|recent|这周|这月/i.test(question);
        const indexUrl = isRecent ? '/site-index/news-30d.json' : '/site-index/news-all.json';
        const [blogRes, newsRes] = await Promise.all([
          fetch('/site-index/blog-all.json'),
          fetch(indexUrl),
        ]);
        const blogItems = await blogRes.json();
        const newsItems = await newsRes.json();
        siteIndexCache = { blog: blogItems, news: newsItems };
        return siteIndexCache;
      };

      const SEARCH_STOP_WORDS = new Set([
        '搜索', '搜一下', '搜', '本网站', '本站', '网站', '相关文章', '文章', '内容', '总结', '总结下', '总结一下', '给我', '看看', '关于',
        'search', 'site', 'website', 'article', 'articles', 'post', 'posts', 'summary', 'summarize', 'about', 'find', 'show', 'me',
      ]);

      const normalizeToken = (token) => token
        .toLowerCase()
        .replace(/[，。！？；：、“”‘’（）【】《》,.!?;:()[\]{}"']/g, '')
        .trim();

      const getQueryTerms = (query) => {
        const lowered = query.toLowerCase();
        const asciiTerms = lowered.match(/[a-z0-9]+(?:[-_.][a-z0-9]+)*/g) || [];
        const zhSegments = lowered
          .replace(/[a-z0-9]+(?:[-_.][a-z0-9]+)*/g, ' ')
          .split(/\s+/)
          .map(normalizeToken)
          .filter(Boolean)
          .flatMap((segment) => {
            if (segment.length <= 4) return [segment];
            const grams = [];
            for (let i = 0; i <= segment.length - 2; i += 1) grams.push(segment.slice(i, i + 2));
            for (let i = 0; i <= segment.length - 3; i += 1) grams.push(segment.slice(i, i + 3));
            return [segment, ...grams];
          });

        const rawTerms = [...asciiTerms, ...zhSegments]
          .map(normalizeToken)
          .filter(Boolean)
          .filter((term) => !SEARCH_STOP_WORDS.has(term));

        return [...new Set(rawTerms)].sort((a, b) => b.length - a.length);
      };

      const searchIndex = (index, query) => {
        const terms = getQueryTerms(query);
        const collectMatches = (text, term) => {
          const matches = [];
          let start = 0;
          while (start < text.length) {
            const at = text.indexOf(term, start);
            if (at === -1) break;
            matches.push(at);
            start = at + term.length;
          }
          return matches;
        };

        const scoreItem = (item) => {
          const title = (item.title || '').toLowerCase();
          const description = (item.description || '').toLowerCase();
          const tags = (item.tags || []).join(' ').toLowerCase();
          const body = (item.body || '').toLowerCase();
          const score = terms.reduce((sum, term) => {
            const baseWeight = /[a-z0-9]/.test(term) ? 6 : term.length >= 3 ? 3 : 1;
            const titleHits = collectMatches(title, term).length;
            const descriptionHits = collectMatches(description, term).length;
            const tagHits = collectMatches(tags, term).length;
            const bodyHits = Math.min(collectMatches(body, term).length, 4);
            return sum + titleHits * baseWeight * 8 + descriptionHits * baseWeight * 4 + tagHits * baseWeight * 5 + bodyHits * baseWeight;
          }, 0);

          const freshnessBoost = item._type === 'news'
            ? Math.max(0, 30 - Math.floor((Date.now() - new Date(item.pubDate).getTime()) / 86400000))
            : 0;

          return score + freshnessBoost;
        };
        const scored = [...index.blog.map(i => ({...i, _type: 'blog', _score: scoreItem(i)})), ...index.news.map(i => ({...i, _type: 'news', _score: scoreItem(i)}))];
        return scored.filter(i => i._score > 0).sort((a, b) => b._score - a._score).slice(0, 10);
      };

      const SYSTEM_PROMPT = '你是一个 AI 助手，帮助用户了解这个个人站点的博客文章和新闻动态。请基于提供的站点内容回答问题。如果内容不足以回答，请诚实说明。回答使用中文，除非用户用英文提问。';

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const query = input.value.trim();
        if (!query) return;
        if (!apiKeyInput.value) {
          addMsg('error', '请先在设置中填写 API Key（点击 ⚙）');
          return;
        }
        if (!baseUrlInput.value.trim()) {
          addMsg('error', providerSelect.value === 'compatible'
            ? '请先填写支持浏览器直连的 Base URL。'
            : '这个静态站不能直连官方接口。请先填写你自己的代理 Base URL。');
          return;
        }
        addMsg('user', query);
        input.value = '';

        try {
          const index = await loadSiteIndex(query);
          const results = searchIndex(index, query);
          const contextText = results.map(r => `[${r._type}] ${r.title} (${r.pubDate})\n${r.description}\n${(r.body || '').slice(0, 300)}`).join('\n\n');

          const userContent = contextText
            ? `相关站点内容：\n${contextText}\n\n用户问题：${query}`
            : `用户问题：${query}`;

          const p = providerSelect.value;
          const messages = p === 'claude'
            ? [{ role: 'user', content: SYSTEM_PROMPT + '\n\n' + userContent }]
            : [{ role: 'system', content: SYSTEM_PROMPT }, { role: 'user', content: userContent }];

          const res = await fetch(getEndpoint(), {
            method: 'POST',
            headers: getHeaders(),
            body: buildBody(messages),
          });

          if (!res.ok) {
            const err = await res.text();
            addMsg('error', `请求失败：${res.status}\n${err.slice(0, 280)}`);
            return;
          }

          const data = await res.json();
          const reply = p === 'claude'
            ? (data.content?.[0]?.text || '无回复')
            : (data.choices?.[0]?.message?.content || '无回复');
          addMsg('assistant', reply);
          addSourcesMsg(results.slice(0, 5));
        } catch (err) {
          const message = err?.message || String(err);
          if (/Failed to fetch|NetworkError|Load failed/i.test(message)) {
            addMsg('error', '网络请求被浏览器拦住了。通常是 CORS 或代理地址不可用。\n\n如果你选的是 OpenAI / Claude，请填写你自己的代理 Base URL。\n如果你选的是 OpenAI Compatible，请确认这个服务允许浏览器直连。');
            return;
          }
          addMsg('error', '出错了：' + message);
        }
      });

      const revealNodes = document.querySelectorAll('.reveal');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      revealNodes.forEach((node) => revealObserver.observe(node));

      navDropdowns.forEach((dropdown) => {
        const trigger = dropdown.querySelector('.nav-dropdown-trigger');
        const menu = dropdown.querySelector('.nav-dropdown-menu');
        if (!trigger || !menu) return;
        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleNavDropdown(dropdown);
        });
      });

      document.addEventListener('click', (e) => {
        navDropdowns.forEach((dropdown) => {
          if (!dropdown.contains(e.target)) closeNavDropdown(dropdown);
        });
      });

      const mobileToggle = document.getElementById('mobile-nav-toggle');
      const headerActions = document.querySelector('.header-actions');
      if (mobileToggle && headerActions) {
        mobileToggle.addEventListener('click', () => {
          const isOpen = mobileToggle.getAttribute('aria-expanded') === 'true';
          mobileToggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
          headerActions.classList.toggle('mobile-nav-open', !isOpen);
        });
        document.addEventListener('click', (e) => {
          if (mobileToggle.getAttribute('aria-expanded') === 'true' &&
              !e.target.closest('.header-row')) {
            mobileToggle.setAttribute('aria-expanded', 'false');
            headerActions.classList.remove('mobile-nav-open');
          }
        });
      }

      const header = document.getElementById('site-header');
      if (header) {
        let scrolled = false;
        const onScroll = () => {
          const next = window.scrollY > 20;
          if (next !== scrolled) {
            scrolled = next;
            header.classList.toggle('header-scrolled', next);
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    })();
    </script>
  </body>
</html>
