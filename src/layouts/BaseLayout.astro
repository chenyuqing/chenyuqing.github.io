        const root = document.documentElement;
        const langButton = document.getElementById('lang-toggle');
        const themeButton = document.getElementById('theme-toggle');

        const resolveLang = (value) => (value === 'en' ? 'en' : 'zh');
        const resolveTheme = (value) => (value === 'dark' ? 'dark' : 'light');
        const VISIT_STATS_KEY = 'site-visit-stats-v1';
        const BROWSE_HISTORY_KEY = 'site-browse-history-v1';
        const HISTORY_LIMIT = 10;
        let latestTrackingData = null;

        const safeJsonParse = (raw, fallback) => {
          if (!raw) return fallback;
          try {
            return JSON.parse(raw);
          } catch {
            return fallback;
          }
        };

        const applyTranslations = (lang) => {
          const dict = I18N[lang] ?? I18N.zh;
          document.querySelectorAll('[data-i18n]').forEach((node) => {
            const key = node.getAttribute('data-i18n');
            if (!key) return;
            const value = dict[key];
            if (typeof value === 'string') node.textContent = value;
          });
          document.querySelectorAll('[data-i18n-alt]').forEach((node) => {
            const key = node.getAttribute('data-i18n-alt');
            if (!key) return;
            const value = dict[key];
            if (typeof value === 'string') node.setAttribute('alt', value);
          });
          document.querySelectorAll('[data-i18n-aria-label]').forEach((node) => {
            const key = node.getAttribute('data-i18n-aria-label');
            if (!key) return;
            const value = dict[key];
            if (typeof value === 'string') node.setAttribute('aria-label', value);
          });
        };

        const formatVisitTime = (iso, lang) => {
          if (!iso) return '--';
          const date = new Date(iso);
          if (Number.isNaN(date.getTime())) return '--';
          return date.toLocaleString(lang === 'en' ? 'en-US' : 'zh-CN', { hour12: false });
        };

        const renderTrackingPanels = () => {
          if (!latestTrackingData) return;
          const lang = resolveLang(root.getAttribute('data-lang'));
          const dict = I18N[lang] ?? I18N.zh;
          const { stats, history } = latestTrackingData;

          const totalEl = document.querySelector('[data-visit-total]');
          const uniqueEl = document.querySelector('[data-visit-unique]');
          const lastEl = document.querySelector('[data-visit-last]');
          if (totalEl) totalEl.textContent = String(stats.totalVisits ?? 0);
          if (uniqueEl) uniqueEl.textContent = String(Object.keys(stats.uniquePathCount ?? {}).length);
          if (lastEl) lastEl.textContent = formatVisitTime(stats.lastVisitAt, lang);

          const listEl = document.querySelector('[data-browse-list]');
          if (!listEl) return;
          listEl.innerHTML = '';
          if (!Array.isArray(history) || history.length === 0) {
            const empty = document.createElement('li');
            empty.className = 'history-empty';
            empty.textContent = dict.home_history_empty ?? 'No history yet';
            listEl.appendChild(empty);
            return;
          }
          history.forEach((item) => {
            const row = document.createElement('li');
            row.className = 'history-item';

            const link = document.createElement('a');
            link.className = 'history-link';
            link.href = item.path || '/';
            link.textContent = item.title || item.path || '/';

            const time = document.createElement('span');
            time.className = 'history-time';
            time.textContent = formatVisitTime(item.visitedAt, lang);

            row.appendChild(link);
            row.appendChild(time);
            listEl.appendChild(row);
          });
        };

        const trackVisit = () => {
          const path = `${window.location.pathname}${window.location.search || ''}`;
          const nowIso = new Date().toISOString();
          const cleanedTitle = document.title.replace(/\s*\|\s*Tim Chen\s*$/i, '').trim();
          const pageTitle = cleanedTitle || path;

          const stats = safeJsonParse(localStorage.getItem(VISIT_STATS_KEY), {
            totalVisits: 0,
            lastVisitAt: '',
            uniquePathCount: {},
          });
          if (typeof stats.uniquePathCount !== 'object' || !stats.uniquePathCount) {
            stats.uniquePathCount = {};
          }
          stats.totalVisits = Number(stats.totalVisits || 0) + 1;
          stats.lastVisitAt = nowIso;
          stats.uniquePathCount[path] = Number(stats.uniquePathCount[path] || 0) + 1;
          localStorage.setItem(VISIT_STATS_KEY, JSON.stringify(stats));

          const historyRaw = safeJsonParse(localStorage.getItem(BROWSE_HISTORY_KEY), []);
          const history = Array.isArray(historyRaw) ? historyRaw : [];
          const nextHistory = history
            .filter((item) => item && typeof item.path === 'string' && item.path !== path)
            .slice(0, HISTORY_LIMIT - 1);
          nextHistory.unshift({
            path,
            title: pageTitle,
            visitedAt: nowIso,
          });
          localStorage.setItem(BROWSE_HISTORY_KEY, JSON.stringify(nextHistory));

          latestTrackingData = {
            stats,
            history: nextHistory,
          };
        };

        const applyThemeLabel = (lang, theme) => {
          if (!themeButton) return;
          const dict = I18N[lang] ?? I18N.zh;
          const key = theme === 'dark' ? 'theme_dark_label' : 'theme_light_label';
          const text = dict[key] ?? key;
          themeButton.textContent = text;
          themeButton.setAttribute('data-theme-state', theme);
        };

        const setLang = (nextLang) => {
          const lang = resolveLang(nextLang);
          root.setAttribute('data-lang', lang);
          root.setAttribute('lang', lang === 'en' ? 'en' : 'zh-CN');
          localStorage.setItem('site-lang', lang);
          applyTranslations(lang);
          applyThemeLabel(lang, resolveTheme(root.getAttribute('data-theme')));
          renderTrackingPanels();
        };

        const setTheme = (nextTheme) => {
          const theme = resolveTheme(nextTheme);
          root.setAttribute('data-theme', theme);
          localStorage.setItem('site-theme', theme);
          applyThemeLabel(resolveLang(root.getAttribute('data-lang')), theme);
        };

        trackVisit();
        setLang(resolveLang(root.getAttribute('data-lang')));
        setTheme(resolveTheme(root.getAttribute('data-theme')));
        renderTrackingPanels();

        langButton?.addEventListener('click', () => {
          const current = resolveLang(root.getAttribute('data-lang'));
          setLang(current === 'zh' ? 'en' : 'zh');
        });

        themeButton?.addEventListener('click', () => {
          const current = resolveTheme(root.getAttribute('data-theme'));
          setTheme(current === 'light' ? 'dark' : 'light');
        });
      })();
    </script>
    <button id="ai-agent-btn" class="ai-fab" aria-label="AI Agent" data-i18n-aria-label="ai_agent_aria">AI</button>

    <aside id="ai-agent-panel" class="ai-panel" aria-hidden="true">
      <div class="ai-panel-head">
        <strong data-i18n="ai_agent_title">AI 问答</strong>
        <button id="ai-panel-close" class="ai-panel-close" aria-label="关闭">×</button>
      </div>
      <div class="ai-panel-settings" id="ai-settings">
        <button id="ai-settings-toggle" class="ai-settings-toggle" aria-label="设置">⚙</button>
        <div id="ai-settings-body" class="ai-settings-body" hidden>
          <label class="ai-setting-row">
            <span data-i18n="ai_provider">Provider</span>
            <select id="ai-provider" class="ai-input">
              <option value="openai">OpenAI</option>
              <option value="claude">Claude</option>
              <option value="compatible">OpenAI Compatible</option>
            </select>
          </label>
          <label class="ai-setting-row" id="ai-base-url-row" hidden>
            <span data-i18n="ai_base_url">Base URL</span>
            <input id="ai-base-url" class="ai-input" type="url" placeholder="https://api.example.com/v1" />
          </label>
          <label class="ai-setting-row">
            <span data-i18n="ai_model">Model</span>
            <input id="ai-model" class="ai-input" type="text" placeholder="gpt-4o-mini" value="gpt-4o-mini" />
          </label>
          <label class="ai-setting-row">
            <span data-i18n="ai_api_key">API Key</span>
            <input id="ai-api-key" class="ai-input" type="password" placeholder="sk-..." />
          </label>
        </div>
      </div>
      <div id="ai-messages" class="ai-messages">
        <div class="ai-welcome" data-i18n="ai_welcome">问我关于这个站点的任何内容。</div>
      </div>
      <form id="ai-form" class="ai-form">
        <input id="ai-input" class="ai-input ai-query-input" type="text" autocomplete="off" data-i18n-placeholder="ai_placeholder" placeholder="搜索文章、问问题..." />
        <button class="ai-send-btn" type="submit" aria-label="发送">→</button>
      </form>
    </aside>

    <script is:inline>
    (() => {
      const fab = document.getElementById('ai-agent-btn');
      const panel = document.getElementById('ai-agent-panel');
      const closeBtn = document.getElementById('ai-panel-close');
      const settingsToggle = document.getElementById('ai-settings-toggle');
      const settingsBody = document.getElementById('ai-settings-body');
      const providerSelect = document.getElementById('ai-provider');
      const baseUrlRow = document.getElementById('ai-base-url-row');
      const baseUrlInput = document.getElementById('ai-base-url');
      const modelInput = document.getElementById('ai-model');
      const apiKeyInput = document.getElementById('ai-api-key');
      const messagesEl = document.getElementById('ai-messages');
      const form = document.getElementById('ai-form');
      const input = document.getElementById('ai-input');
      const introAiTrigger = document.getElementById('intro-ai-trigger');
      const footerAiTrigger = document.getElementById('footer-ai-trigger');

      const STORAGE_KEY = 'ai-agent-config-v1';

      const loadConfig = () => {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return;
          const c = JSON.parse(raw);
          if (c.provider) providerSelect.value = c.provider;
          if (c.baseUrl) baseUrlInput.value = c.baseUrl;
          if (c.model) modelInput.value = c.model;
          if (c.apiKey) apiKeyInput.value = c.apiKey;
        } catch {}
        providerSelect.dispatchEvent(new Event('change'));
      };

      const saveConfig = () => {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          provider: providerSelect.value,
          baseUrl: baseUrlInput.value,
          model: modelInput.value,
          apiKey: apiKeyInput.value,
        }));
      };

      fab?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', panel.getAttribute('aria-hidden') === 'true' ? 'false' : 'true');
      });

      introAiTrigger?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', 'false');
        input?.focus();
      });

      footerAiTrigger?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', 'false');
        input?.focus();
      });

      closeBtn?.addEventListener('click', () => {
        panel.setAttribute('aria-hidden', 'true');
      });

      settingsToggle?.addEventListener('click', () => {
        settingsBody.hidden = !settingsBody.hidden;
      });

      providerSelect?.addEventListener('change', () => {
        const v = providerSelect.value;
        baseUrlRow.hidden = v !== 'compatible';
        if (v === 'openai') modelInput.placeholder = modelInput.value = 'gpt-4o-mini';
        else if (v === 'claude') modelInput.placeholder = modelInput.value = 'claude-sonnet-4-20250514';
        else modelInput.placeholder = 'deepseek-chat';
        saveConfig();
      });

      [baseUrlInput, modelInput, apiKeyInput].forEach(el => {
        el?.addEventListener('change', saveConfig);
      });

      loadConfig();

      const getEndpoint = () => {
        const p = providerSelect.value;
        if (p === 'openai') return 'https://api.openai.com/v1/chat/completions';
        if (p === 'claude') return 'https://api.anthropic.com/v1/messages';
        const base = baseUrlInput.value.replace(/\/+$/, '');
        return base + '/chat/completions';
      };

      const getHeaders = () => {
        const p = providerSelect.value;
        const key = apiKeyInput.value;
        if (p === 'claude') return {
          'Content-Type': 'application/json',
          'x-api-key': key,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true',
        };
        return {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + key,
        };
      };

      const buildBody = (messages) => {
        const p = providerSelect.value;
        const model = modelInput.value;
        if (p === 'claude') return JSON.stringify({
          model,
          max_tokens: 1024,
          messages,
        });
        return JSON.stringify({ model, messages, max_tokens: 1024 });
      };

      const addMsg = (role, text) => {
        const div = document.createElement('div');
        div.className = 'ai-msg ai-msg-' + role;
        div.textContent = text;
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      };

      let siteIndexCache = null;

      const loadSiteIndex = async (question) => {
        if (siteIndexCache) return siteIndexCache;
        const isRecent = /最近|近期|latest|recent|这周|这月/i.test(question);
        const indexUrl = isRecent ? '/site-index/news-30d.json' : '/site-index/news-90d.json';
        const [blogRes, newsRes] = await Promise.all([
          fetch('/site-index/blog-all.json'),
          fetch(indexUrl),
        ]);
        const blogItems = await blogRes.json();
        const newsItems = await newsRes.json();
        siteIndexCache = { blog: blogItems, news: newsItems };
        return siteIndexCache;
      };

      const searchIndex = (index, query) => {
        const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
        const scoreItem = (item) => {
          const text = ((item.title || '') + ' ' + (item.description || '') + ' ' + (item.tags || []).join(' ') + ' ' + (item.body || '')).toLowerCase();
          return terms.reduce((s, t) => s + (text.includes(t) ? 1 : 0), 0);
        };
        const scored = [...index.blog.map(i => ({...i, _type: 'blog', _score: scoreItem(i)})), ...index.news.map(i => ({...i, _type: 'news', _score: scoreItem(i)}))];
        return scored.filter(i => i._score > 0).sort((a, b) => b._score - a._score).slice(0, 10);
      };

      const SYSTEM_PROMPT = '你是一个 AI 助手，帮助用户了解这个个人站点的博客文章和新闻动态。请基于提供的站点内容回答问题。如果内容不足以回答，请诚实说明。回答使用中文，除非用户用英文提问。';

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const query = input.value.trim();
        if (!query) return;
        if (!apiKeyInput.value) {
          addMsg('error', '请先在设置中填写 API Key（点击 ⚙）');
          return;
        }
        addMsg('user', query);
        input.value = '';

        try {
          const index = await loadSiteIndex(query);
          const results = searchIndex(index, query);
          const contextText = results.map(r => `[${r._type}] ${r.title} (${r.pubDate})\n${r.description}\n${(r.body || '').slice(0, 300)}`).join('\n\n');

          const userContent = contextText
            ? `相关站点内容：\n${contextText}\n\n用户问题：${query}`
            : `用户问题：${query}`;

          const p = providerSelect.value;
          const messages = p === 'claude'
            ? [{ role: 'user', content: SYSTEM_PROMPT + '\n\n' + userContent }]
            : [{ role: 'system', content: SYSTEM_PROMPT }, { role: 'user', content: userContent }];

          const res = await fetch(getEndpoint(), {
            method: 'POST',
            headers: getHeaders(),
            body: buildBody(messages),
          });

          if (!res.ok) {
            const err = await res.text();
            addMsg('error', '请求失败：' + res.status);
            return;
          }

          const data = await res.json();
          const reply = p === 'claude'
            ? (data.content?.[0]?.text || '无回复')
            : (data.choices?.[0]?.message?.content || '无回复');
          addMsg('assistant', reply);
        } catch (err) {
          addMsg('error', '出错了：' + (err.message || String(err)));
        }
      });

      const revealNodes = document.querySelectorAll('.reveal');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      revealNodes.forEach((node) => revealObserver.observe(node));

      const dropdown = document.getElementById('nav-content-dropdown');
      const dropdownTrigger = dropdown?.querySelector('.nav-dropdown-trigger');
      const dropdownMenu = dropdown?.querySelector('.nav-dropdown-menu');

      if (dropdown && dropdownTrigger && dropdownMenu) {
        dropdownTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = dropdown.classList.toggle('dropdown-open');
          dropdownTrigger.setAttribute('aria-expanded', open);
        });
        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target)) {
            dropdown.classList.remove('dropdown-open');
            dropdownTrigger.setAttribute('aria-expanded', 'false');
          }
        });
      }

      const header = document.getElementById('site-header');
      if (header) {
        let scrolled = false;
        const onScroll = () => {
          const next = window.scrollY > 20;
          if (next !== scrolled) {
            scrolled = next;
            header.classList.toggle('header-scrolled', next);
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    })();
    </script>
  </body>
