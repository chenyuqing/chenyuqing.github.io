---
const {
  title = 'Tim Chen',
  description = 'Tim Chen 的个人站点。',
  canonical,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonicalUrl = canonical ? new URL(canonical, Astro.site ?? 'https://chenyuqing.github.io').toString() : undefined;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!doctype html>
<html lang="zh-CN" data-lang="zh" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script define:vars={{ gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', gaMeasurementId, {
            anonymize_ip: true,
          });
        </script>
      </>
    )}
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storedLang = localStorage.getItem('site-lang');
        const storedTheme = localStorage.getItem('site-theme');
        const lang = storedLang === 'en' ? 'en' : 'zh';
        const theme = storedTheme === 'dark'
          ? 'dark'
          : storedTheme === 'light'
            ? 'light'
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        root.setAttribute('data-lang', lang);
        root.setAttribute('data-theme', theme);
        root.setAttribute('lang', lang === 'en' ? 'en' : 'zh-CN');
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content" data-i18n="skip_to_content">跳到内容</a>
    <header class="site-header">
      <div class="shell header-row">
        <a class="brand" href="/" aria-label="返回首页">
          <span class="brand-mark">
            <img src="/favicon-64x64.png" alt="Tim Chen avatar" />
          </span>
          <span class="brand-text">
            <strong>Tim Chen</strong>
            <small>creator lab</small>
          </span>
        </a>
        <div class="header-actions">
          <nav class="site-nav" aria-label="Primary">
            <a class="nav-pill" href="/" aria-current={pathname === '/' ? 'page' : undefined} data-i18n="nav_home">首页</a>
            <a class="nav-pill" href="/about/" aria-current={pathname.startsWith('/about') ? 'page' : undefined} data-i18n="nav_about">关于</a>
            <a class="nav-pill" href="/blog/" aria-current={pathname.startsWith('/blog') ? 'page' : undefined} data-i18n="nav_blog">博客</a>
            <a class="nav-pill" href="https://github.com/chenyuqing" target="_blank" rel="noreferrer" data-i18n="nav_github">GitHub</a>
          </nav>
          <div class="site-controls">
            <button
              id="lang-toggle"
              class="nav-pill toggle-pill"
              type="button"
              data-i18n-aria-label="toggle_lang_aria"
              data-i18n="toggle_lang_button"
            >
              中 / EN
            </button>
            <button
              id="theme-toggle"
              class="nav-pill toggle-pill"
              type="button"
              data-i18n-aria-label="toggle_theme_aria"
              data-i18n="theme_light_label"
            >
              浅色模式
            </button>
          </div>
        </div>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="shell footer-row">
        <p data-i18n="footer_copy">2026 © Tim Chen · AI Creator Playground</p>
        <div class="footer-links">
          <a class="nav-pill" href="/" data-i18n="footer_home">首页</a>
          <a class="nav-pill" href="/about/" data-i18n="footer_about">关于</a>
          <a class="nav-pill" href="/blog/" data-i18n="footer_blog">博客</a>
        </div>
      </div>
    </footer>
