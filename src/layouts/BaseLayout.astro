        const root = document.documentElement;
        const langButton = document.getElementById('lang-toggle');
        const themeButton = document.getElementById('theme-toggle');

        const resolveLang = (value) => (value === 'en' ? 'en' : 'zh');
        const resolveTheme = (value) => (value === 'dark' ? 'dark' : 'light');
        const VISIT_STATS_KEY = 'site-visit-stats-v1';
        const BROWSE_HISTORY_KEY = 'site-browse-history-v1';
        const HISTORY_LIMIT = 10;
        let latestTrackingData = null;

        const safeJsonParse = (raw, fallback) => {
          if (!raw) return fallback;
          try {
            return JSON.parse(raw);
          } catch {
            return fallback;
          }
        };

        const applyTranslations = (lang) => {
          const dict = I18N[lang] ?? I18N.zh;
          document.querySelectorAll('[data-i18n]').forEach((node) => {
            const key = node.getAttribute('data-i18n');
            if (!key) return;
            const value = dict[key];
            if (typeof value === 'string') node.textContent = value;
          });
          document.querySelectorAll('[data-i18n-alt]').forEach((node) => {
            const key = node.getAttribute('data-i18n-alt');
            if (!key) return;
            const value = dict[key];
            if (typeof value === 'string') node.setAttribute('alt', value);
          });
          document.querySelectorAll('[data-i18n-aria-label]').forEach((node) => {
            const key = node.getAttribute('data-i18n-aria-label');
            if (!key) return;
            const value = dict[key];
            if (typeof value === 'string') node.setAttribute('aria-label', value);
          });
        };

        const formatVisitTime = (iso, lang) => {
          if (!iso) return '--';
          const date = new Date(iso);
          if (Number.isNaN(date.getTime())) return '--';
          return date.toLocaleString(lang === 'en' ? 'en-US' : 'zh-CN', { hour12: false });
        };

        const renderTrackingPanels = () => {
          if (!latestTrackingData) return;
          const lang = resolveLang(root.getAttribute('data-lang'));
          const dict = I18N[lang] ?? I18N.zh;
          const { stats, history } = latestTrackingData;

          const totalEl = document.querySelector('[data-visit-total]');
          const uniqueEl = document.querySelector('[data-visit-unique]');
          const lastEl = document.querySelector('[data-visit-last]');
          if (totalEl) totalEl.textContent = String(stats.totalVisits ?? 0);
          if (uniqueEl) uniqueEl.textContent = String(Object.keys(stats.uniquePathCount ?? {}).length);
          if (lastEl) lastEl.textContent = formatVisitTime(stats.lastVisitAt, lang);

          const listEl = document.querySelector('[data-browse-list]');
          if (!listEl) return;
          listEl.innerHTML = '';
          if (!Array.isArray(history) || history.length === 0) {
            const empty = document.createElement('li');
            empty.className = 'history-empty';
            empty.textContent = dict.home_history_empty ?? 'No history yet';
            listEl.appendChild(empty);
            return;
          }
          history.forEach((item) => {
            const row = document.createElement('li');
            row.className = 'history-item';

            const link = document.createElement('a');
            link.className = 'history-link';
            link.href = item.path || '/';
            link.textContent = item.title || item.path || '/';

            const time = document.createElement('span');
            time.className = 'history-time';
            time.textContent = formatVisitTime(item.visitedAt, lang);

            row.appendChild(link);
            row.appendChild(time);
            listEl.appendChild(row);
          });
        };

        const trackVisit = () => {
          const path = `${window.location.pathname}${window.location.search || ''}`;
          const nowIso = new Date().toISOString();
          const cleanedTitle = document.title.replace(/\s*\|\s*Tim Chen\s*$/i, '').trim();
          const pageTitle = cleanedTitle || path;

          const stats = safeJsonParse(localStorage.getItem(VISIT_STATS_KEY), {
            totalVisits: 0,
            lastVisitAt: '',
            uniquePathCount: {},
          });
          if (typeof stats.uniquePathCount !== 'object' || !stats.uniquePathCount) {
            stats.uniquePathCount = {};
          }
          stats.totalVisits = Number(stats.totalVisits || 0) + 1;
          stats.lastVisitAt = nowIso;
          stats.uniquePathCount[path] = Number(stats.uniquePathCount[path] || 0) + 1;
          localStorage.setItem(VISIT_STATS_KEY, JSON.stringify(stats));

          const historyRaw = safeJsonParse(localStorage.getItem(BROWSE_HISTORY_KEY), []);
          const history = Array.isArray(historyRaw) ? historyRaw : [];
          const nextHistory = history
            .filter((item) => item && typeof item.path === 'string' && item.path !== path)
            .slice(0, HISTORY_LIMIT - 1);
          nextHistory.unshift({
            path,
            title: pageTitle,
            visitedAt: nowIso,
          });
          localStorage.setItem(BROWSE_HISTORY_KEY, JSON.stringify(nextHistory));

          latestTrackingData = {
            stats,
            history: nextHistory,
          };
        };

        const applyThemeLabel = (lang, theme) => {
          if (!themeButton) return;
          const dict = I18N[lang] ?? I18N.zh;
          const key = theme === 'dark' ? 'theme_dark_label' : 'theme_light_label';
          const text = dict[key] ?? key;
          themeButton.textContent = text;
          themeButton.setAttribute('data-theme-state', theme);
        };

        const setLang = (nextLang) => {
          const lang = resolveLang(nextLang);
          root.setAttribute('data-lang', lang);
          root.setAttribute('lang', lang === 'en' ? 'en' : 'zh-CN');
          localStorage.setItem('site-lang', lang);
          applyTranslations(lang);
          applyThemeLabel(lang, resolveTheme(root.getAttribute('data-theme')));
          renderTrackingPanels();
        };

        const setTheme = (nextTheme) => {
          const theme = resolveTheme(nextTheme);
          root.setAttribute('data-theme', theme);
          localStorage.setItem('site-theme', theme);
          applyThemeLabel(resolveLang(root.getAttribute('data-lang')), theme);
        };

        trackVisit();
        setLang(resolveLang(root.getAttribute('data-lang')));
        setTheme(resolveTheme(root.getAttribute('data-theme')));
        renderTrackingPanels();

        langButton?.addEventListener('click', () => {
          const current = resolveLang(root.getAttribute('data-lang'));
          setLang(current === 'zh' ? 'en' : 'zh');
        });

        themeButton?.addEventListener('click', () => {
          const current = resolveTheme(root.getAttribute('data-theme'));
          setTheme(current === 'light' ? 'dark' : 'light');
        });
      })();
    </script>
