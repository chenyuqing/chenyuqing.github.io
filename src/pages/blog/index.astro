---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    const featuredSlug = 'how-to-read-this-site';
    if (a.id === featuredSlug) return -1;
    if (b.id === featuredSlug) return 1;
    return b.data.pubDate.getTime() - a.data.pubDate.getTime();
  });

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();

const currentTag = Astro.url.searchParams.get('tag') || '';
const posts = currentTag
  ? allPosts.filter((post) => post.data.tags.includes(currentTag))
  : allPosts;

const tagSearch = (tag: string) => {
  const url = new URL(Astro.url);
  if (tag) { url.searchParams.set('tag', tag); } else { url.searchParams.delete('tag'); }
  return url.pathname + url.search;
};

const seenSeries = new Set<string>();
---

<BaseLayout title="博客 | Tim Chen" description="Tim Chen 的博客文章。">
  <main id="content" class="shell page-simple">
    <section class="section blog-page-shell">
      <div class="section-head">
        <p class="eyebrow" data-i18n="blog_page_eyebrow">Podcast</p>
        <h1 class="section-title" data-i18n="blog_page_title">播客文章</h1>
        <p class="section-desc" data-i18n="blog_page_desc">深度文章、教程与思考。</p>
      </div>

      <div class="tag-filter">
        <a class={`tag ${!currentTag ? 'tag-active' : ''}`} href={tagSearch('')}>全部</a>
        {allTags.map((tag) => (
          <a class={`tag tag-ai ${currentTag === tag ? 'tag-active' : ''}`} href={tagSearch(tag)}>{tag}</a>
        ))}
      </div>

      <div class="magazine-list magazine-list-page">
        {posts.length === 0 ? (
          <article class="magazine-card magazine-card-featured">
            <p class="muted" data-i18n="blog_page_empty">暂无文章。</p>
          </article>
        ) : (
          posts.map((post, index) => {
            const showSeriesHeader = post.data.series && !seenSeries.has(post.data.series);
            if (post.data.series) seenSeries.add(post.data.series);
            return (
              <>
                {showSeriesHeader && (
                  <div class="series-badge">
                    <span class="tag tag-code" data-i18n="blog_series">系列</span>
                    <span class="series-name">{post.data.series}</span>
                  </div>
                )}
                <article class={`magazine-card ${index === 0 ? 'magazine-card-featured' : ''}`}>
                  {post.data.cover && (
                    <a class="magazine-card-img-link" href={`/blog/${post.id}/`}>
                      <img class="magazine-card-img" src={post.data.cover} alt={post.data.title} />
                    </a>
                  )}
                  <div class="magazine-card-body">
                    <div class="magazine-card-eyebrow">
                      {post.data.verdict && (
                        <span class={`tag tag-verdict tag-verdict-${post.data.verdict}`}>{post.data.verdict}</span>
                      )}
                    </div>
                    <a class="magazine-card-title" href={`/blog/${post.id}/`}>
                      <h2>{post.data.title}</h2>
                    </a>
                    {post.data.description && <p class="magazine-card-desc">{post.data.description}</p>}
                    <div class="post-meta magazine-card-meta">
                      <span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
                      {post.data.tags.map((tag) => (
                        <span class="tag tag-code">{tag}</span>
                      ))}
                    </div>
                  </div>
                </article>
              </>
            );
          })
        )}
      </div>
    </section>
  </main>
</BaseLayout>
