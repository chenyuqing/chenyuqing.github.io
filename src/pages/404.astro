---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="页面未找到 | Tim Chen" description="这个页面不存在。">
  <main id="content" class="shell">
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">404</p>
        <h1 class="section-title">页面未找到</h1>
        <p class="section-desc">旧内容路径、归档页和标签页都已下线。请从首页重新开始浏览。</p>
      </div>
      <div class="actions">
        <a class="pill" href="/">回首页</a>
        <a class="pill" href="/about/">看关于</a>
      </div>
    </section>
  </main>
</BaseLayout>
