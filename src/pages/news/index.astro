---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const DAYS_PER_PAGE = 3;

const CATEGORIES = ['模型与智能体', '工具与应用', '机器人与硬件', '商业与生态', '安全与评测'];

const categoryColors: Record<string, string> = {
  '模型与智能体': 'category-model',
  '工具与应用': 'category-tool',
  '机器人与硬件': 'category-hardware',
  '商业与生态': 'category-business',
  '安全与评测': 'category-safety',
};

const allNews = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const allTags = [...new Set(allNews.flatMap((item) => item.data.tags))].sort();

const currentCategory = Astro.url.searchParams.get('category') || '';
const currentTag = Astro.url.searchParams.get('tag') || '';

let filtered = allNews;
if (currentCategory) {
  filtered = filtered.filter((item) => item.data.category === currentCategory);
}
if (currentTag) {
  filtered = filtered.filter((item) => item.data.tags.includes(currentTag));
}

// Group by date string YYYY-MM-DD
const dateGroups = filtered.reduce<Record<string, typeof filtered>>((acc, item) => {
  const key = item.data.pubDate.toISOString().slice(0, 10);
  if (!acc[key]) acc[key] = [];
  acc[key].push(item);
  return acc;
}, {});

const sortedDates = Object.keys(dateGroups).sort((a, b) => b.localeCompare(a));

const pageParam = Number(Astro.url.searchParams.get('page') || '1');
const totalPages = Math.max(1, Math.ceil(sortedDates.length / DAYS_PER_PAGE));
const page = Math.min(Math.max(pageParam, 1), totalPages);
const pagedDates = sortedDates.slice((page - 1) * DAYS_PER_PAGE, page * DAYS_PER_PAGE);

const formatDate = (iso: string) => {
  const d = new Date(iso);
  const month = d.getMonth() + 1;
  const day = d.getDate();
  const weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
  return `${month}月${day}日 · ${weekdays[d.getDay()]}`;
};

const searchUrl = (updates: Record<string, string>) => {
  const url = new URL(Astro.url);
  Object.entries(updates).forEach(([key, value]) => {
    if (value) url.searchParams.set(key, value);
    else url.searchParams.delete(key);
  });
  url.searchParams.delete('page');
  return url.pathname + url.search;
};

const pageUrl = (p: number) => {
  const url = new URL(Astro.url);
  url.searchParams.set('page', String(p));
  return url.pathname + url.search;
};
---

<BaseLayout title="动态 | Tim Chen" description="AI 领域最新动态与快讯。">
  <main id="content" class="shell page-simple">
    <section class="section news-page-shell">
      <div class="section-head">
        <p class="eyebrow" data-i18n="news_page_eyebrow">News</p>
        <h1 class="section-title" data-i18n="news_page_title">AI新闻</h1>
        <p class="section-desc" data-i18n="news_page_desc">AI 领域的产品发布、开源项目、论文与行业动态。</p>
      </div>

      <div class="category-filter">
        <a class={`category-pill ${!currentCategory ? 'category-pill-active' : ''}`} href={searchUrl({ category: '' })}>全部</a>
        {CATEGORIES.map((category) => (
          <a class={`category-pill category-pill-${categoryColors[category]} ${currentCategory === category ? 'category-pill-active' : ''}`} href={searchUrl({ category })}>{category}</a>
        ))}
      </div>

      <div class="tag-filter">
        <a class={`tag ${!currentTag ? 'tag-active' : ''}`} href={searchUrl({ tag: '' })}>全部</a>
        {allTags.map((tag) => (
          <a class={`tag tag-ai ${currentTag === tag ? 'tag-active' : ''}`} href={searchUrl({ tag })}>{tag}</a>
        ))}
      </div>

      <div class="news-date-groups">
        {pagedDates.length === 0 ? (
          <p class="muted" data-i18n="news_page_empty">暂无动态。</p>
        ) : (
          pagedDates.map((date) => (
            <section class="news-date-group">
              <h2 class="news-date-title">{formatDate(date)}</h2>
              <div class="news-list news-list-page">
                {dateGroups[date].map((item) => (
                  <article class="news-item news-item-page">
                    <div class="news-item-main">
                      <a class="news-link" href={`/news/${item.id}/`}>
                        <h3>{item.data.title}</h3>
                      </a>
                      {item.data.description && <p class="news-desc">{item.data.description}</p>}
                      <div class="news-meta">
                        <span class={`category-pill category-pill-small category-pill-${categoryColors[item.data.category]}`}>{item.data.category}</span>
                        {item.data.tags.map((tag) => (
                          <span class="tag tag-ai">{tag}</span>
                        ))}
                        {item.data.link && <span class="news-external">↗</span>}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))
        )}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label={currentTag || currentCategory ? '按筛选条件的分页' : '分页'}>
          {page > 1 ? (
            <a class="button button-secondary" href={pageUrl(page - 1)} data-i18n="news_page_prev">上一页</a>
          ) : <span />}
          <span class="page-info">{page} / {totalPages}</span>
          {page < totalPages ? (
            <a class="button button-secondary" href={pageUrl(page + 1)} data-i18n="news_page_next">下一页</a>
          ) : <span />}
        </nav>
      )}
    </section>
  </main>
</BaseLayout>
