---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const PAGE_SIZE = 15;

const allNews = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const allTags = [...new Set(allNews.flatMap((item) => item.data.tags))].sort();

const currentTag = Astro.url.searchParams.get('tag') || '';
const filtered = currentTag
  ? allNews.filter((item) => item.data.tags.includes(currentTag))
  : allNews;

const pageParam = Number(Astro.url.searchParams.get('page') || '1');
const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
const page = Math.min(Math.max(pageParam, 1), totalPages);
const paged = filtered.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
const featured = page === 1 && paged.length > 0 ? paged[0] : null;
const streamItems = page === 1 ? paged.slice(1) : paged;

const tagSearch = (tag: string) => {
  const url = new URL(Astro.url);
  if (tag) { url.searchParams.set('tag', tag); url.searchParams.delete('page'); }
  else { url.searchParams.delete('tag'); url.searchParams.delete('page'); }
  return url.pathname + url.search;
};
const pageUrl = (p: number) => {
  const url = new URL(Astro.url);
  url.searchParams.set('page', String(p));
  return url.pathname + url.search;
};
---

<BaseLayout title="动态 | Tim Chen" description="AI 领域最新动态与快讯。">
  <main id="content" class="shell page-simple">
    <section class="section news-page-shell">
      <div class="section-head">
        <p class="eyebrow" data-i18n="news_page_eyebrow">News</p>
        <h1 class="section-title" data-i18n="news_page_title">AI新闻</h1>
        <p class="section-desc" data-i18n="news_page_desc">AI 领域的产品发布、开源项目、论文与行业动态。</p>
      </div>

      <div class="tag-filter">
        <a class={`tag ${!currentTag ? 'tag-active' : ''}`} href={tagSearch('')}>全部</a>
        {allTags.map((tag) => (
          <a class={`tag tag-ai ${currentTag === tag ? 'tag-active' : ''}`} href={tagSearch(tag)}>{tag}</a>
        ))}
      </div>

      {featured && (
        <a class="news-featured news-featured-light" href={`/news/${featured.id}/`}>
          <div class="news-featured-index news-featured-index-light">01</div>
          {featured.data.cover && (
            <img class="news-featured-img news-featured-img-light" src={featured.data.cover} alt={featured.data.title} />
          )}
          <div class="news-featured-body">
            <h2 class="news-featured-title news-featured-title-light">{featured.data.title}</h2>
            {featured.data.description && <p class="news-featured-desc news-featured-desc-light">{featured.data.description}</p>}
            <div class="news-meta">
              <span>{featured.data.pubDate.toISOString().slice(0, 10)}</span>
              {featured.data.tags.slice(0, 3).map((tag) => (
                <span class="tag tag-ai">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      )}

      <div class="news-list news-list-page">
        {streamItems.length === 0 ? (
          <article class="news-item news-item-page">
            <p class="muted" data-i18n="news_page_empty">暂无动态。</p>
          </article>
        ) : (
          streamItems.map((item, index) => (
            <article class="news-item news-item-page">
              <div class="news-item-index news-item-index-light">{String(index + (featured ? 2 : 1)).padStart(2, '0')}</div>
              <a class="news-link" href={`/news/${item.id}/`}>
                <h3>{item.data.title}</h3>
              </a>
              {item.data.description && <p class="news-desc">{item.data.description}</p>}
              <div class="news-meta">
                <span>{item.data.pubDate.toISOString().slice(0, 10)}</span>
                {item.data.tags.map((tag) => (
                  <span class="tag tag-ai">{tag}</span>
                ))}
              </div>
            </article>
          ))
        )}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label={currentTag ? `按 ${currentTag} 筛选的分页` : '分页'}>
          {page > 1 ? (
            <a class="button button-secondary" href={pageUrl(page - 1)} data-i18n="news_page_prev">上一页</a>
          ) : <span />}
          <span class="page-info">{page} / {totalPages}</span>
          {page < totalPages ? (
            <a class="button button-secondary" href={pageUrl(page + 1)} data-i18n="news_page_next">下一页</a>
          ) : <span />}
        </nav>
      )}
    </section>
  </main>
</BaseLayout>
