---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const fourteenDaysAgo = new Date();
fourteenDaysAgo.setDate(fourteenDaysAgo.getDate() - 14);

const newsItems = (await getCollection('news', ({ data }) => !data.draft))
  .filter(({ data }) => data.pubDate >= fourteenDaysAgo)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);
---

<BaseLayout title="Tim Chen | AI 时代网志" description="AI 时代的个人网志 — 博客、快讯与思考。" canonical="/">
  <main id="content" class="shell">
    <section class="home-intro">
      <h1 class="intro-title">
        <span data-i18n="home_intro_name">Tim Chen</span>
        <span class="intro-sep">·</span>
        <span data-i18n="home_intro_tagline">AI 时代网志</span>
      </h1>
      <p class="intro-lead" data-i18n="home_intro_lead">关注 AI 创作工具、视频工作流和字幕产品，把复杂能力做成简单、可用、好玩的体验。</p>
      <div class="intro-links">
        <a class="intro-link" href="/about/" data-i18n="home_intro_about">关于</a>
        <a class="intro-link" href="/blog/rss.xml" data-i18n="home_intro_rss">RSS</a>
        <a class="intro-link" href="https://github.com/chenyuqing" target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <p class="eyebrow" data-i18n="home_blog_eyebrow">Blog</p>
        <h2 class="section-title" data-i18n="home_blog_title">最新文章</h2>
      </div>
      <div class="blog-list">
        {blogPosts.length === 0 ? (
          <article class="post-card">
            <h2 data-i18n="home_blog_empty">暂无文章</h2>
            <p class="muted" data-i18n="home_blog_empty_hint">新文章正在路上。</p>
          </article>
        ) : (
          blogPosts.map((post) => (
            <article class="post-card">
              {post.data.cover && (
                <a class="post-cover-link" href={`/blog/${post.id}/`}>
                  <img class="post-cover" src={post.data.cover} alt={post.data.title} />
                </a>
              )}
              <a class="post-link" href={`/blog/${post.id}/`}>
                <h2>{post.data.title}</h2>
              </a>
              {post.data.description && <p>{post.data.description}</p>}
              <div class="post-meta">
                <span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
                {post.data.tags.map((tag) => (
                  <span class="tag tag-code">{tag}</span>
                ))}
              </div>
              <div class="actions">
                <a class="button button-secondary" href={`/blog/${post.id}/`} data-i18n="home_blog_read">阅读全文</a>
              </div>
            </article>
          ))
        )}
      </div>
      <div class="section-foot">
        <a class="button button-secondary" href="/blog/" data-i18n="home_blog_more">更多文章</a>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <p class="eyebrow" data-i18n="home_news_eyebrow">News</p>
        <h2 class="section-title" data-i18n="home_news_title">最新动态</h2>
      </div>
      {newsItems.length === 0 ? (
        <article class="news-item">
          <p class="muted" data-i18n="home_news_empty">最近没有新动态。</p>
        </article>
      ) : (
        <div class="news-list">
          {newsItems.map((item) => (
            <article class="news-item">
              <a class="news-link" href={`/news/${item.id}/`}>
                <h3>{item.data.title}</h3>
              </a>
              {item.data.description && <p class="news-desc">{item.data.description}</p>}
              <div class="news-meta">
                <span>{item.data.pubDate.toISOString().slice(0, 10)}</span>
                {item.data.tags.slice(0, 2).map((tag) => (
                  <span class="tag tag-ai">{tag}</span>
                ))}
                {item.data.link && <span class="news-external" data-i18n="home_news_link">🔗 外部链接</span>}
              </div>
            </article>
          ))}
        </div>
      )}
      <div class="section-foot">
        <a class="button button-secondary" href="/news/" data-i18n="home_news_more">更多动态</a>
      </div>
    </section>

    <section class="section">
      <div class="contact-card">
        <div>
          <p class="eyebrow" data-i18n="home_contact_eyebrow">Contact</p>
          <h2 class="section-title" data-i18n="home_contact_title">想一起做点有意思的东西？</h2>
          <p class="section-desc" data-i18n="home_contact_desc">欢迎交流产品、AI、设计和创作流程，我会持续更新这个站点。</p>
          <div class="actions" style="margin-top: 1rem;">
            <a class="button button-primary" href="mailto:tim@dwyx.xyz" data-i18n="home_contact_email">发邮件</a>
            <a class="button button-secondary" href="https://github.com/chenyuqing" target="_blank" rel="noreferrer" data-i18n="home_contact_github">GitHub</a>
          </div>
        </div>
        <aside class="contact-note">
          <p><strong data-i18n="home_contact_note_title">Site</strong></p>
          <p data-i18n="home_contact_note_desc">AI 时代网志 · Astro + GitHub Pages</p>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
