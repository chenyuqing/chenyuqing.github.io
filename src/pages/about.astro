---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="关于 | Tim Chen" description="关于 Tim Chen — AI 创作者、工具 builder、网志作者。" canonical="/about/">
  <main id="content" class="shell page-simple">

    <section class="section about-person">
      <div class="about-person-inner">
        <div class="about-avatar">
          <img src="/media/mascot-elephant.png" alt="Tim Chen" />
        </div>
        <div class="about-bio">
          <h1 class="section-title" data-i18n="about_name">Tim Chen</h1>
          <p class="about-tagline" data-i18n="about_tagline">AI 创作者 · 工具 Builder · 网志作者</p>
          <p class="section-desc" data-i18n="about_bio_desc">我在做 AI 创作工具、视频工作流和字幕产品，把复杂能力做成简单、可用、好玩的体验。这个站点是我的个人网志——写博客、记动态、做实验。</p>
          <div class="actions" style="margin-top: 0.85rem;">
            <a class="button button-primary" href="mailto:tim@dwyx.xyz" data-i18n="about_email">发邮件</a>
            <a class="button button-secondary" href="https://github.com/chenyuqing" target="_blank" rel="noreferrer">GitHub</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <p class="eyebrow" data-i18n="about_projects_eyebrow">Projects</p>
        <h2 class="section-title" data-i18n="about_projects_title">我在做什么</h2>
      </div>
      <div class="project-grid">
        <article class="project-card">
          <span class="project-badge" data-i18n="about_p1_badge">Web 应用</span>
          <h3 data-i18n="about_p1_title">Subtitle Maker</h3>
          <p data-i18n="about_p1_desc">AI 字幕识别、翻译、语音克隆与配音工作流。</p>
          <div class="project-footer">
            <div class="tag-list">
              <span class="tag tag-ai">AI</span>
              <span class="tag tag-video" data-i18n="about_p1_tag2">字幕</span>
              <span class="tag tag-code" data-i18n="about_p1_tag3">配音</span>
            </div>
          </div>
        </article>
        <article class="project-card">
          <span class="project-badge" data-i18n="about_p2_badge">创作工具</span>
          <h3 data-i18n="about_p2_title">Voice Scene Maker</h3>
          <p data-i18n="about_p2_desc">把脚本转换为多语言音频场景的创作工具，面向内容创作者。</p>
          <div class="project-footer">
            <div class="tag-list">
              <span class="tag tag-ai">AI Agent</span>
              <span class="tag tag-design" data-i18n="about_p2_tag2">流程</span>
              <span class="tag tag-code" data-i18n="about_p2_tag3">音频</span>
            </div>
          </div>
        </article>
        <article class="project-card">
          <span class="project-badge" data-i18n="about_p3_badge">个人站点</span>
          <h3 data-i18n="about_p3_title">AI 时代网志</h3>
          <p data-i18n="about_p3_desc">这个站点本身也是一个持续迭代的实验——用 Astro 构建，探索 AI 时代个人网志的可能性。</p>
          <div class="project-footer">
            <div class="tag-list">
              <span class="tag tag-design">Design</span>
              <span class="tag tag-code">Astro</span>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <p class="eyebrow" data-i18n="about_writing_eyebrow">Writing</p>
        <h2 class="section-title" data-i18n="about_writing_title">我写什么</h2>
      </div>
      <div class="feature-grid">
        <article class="card card-writing">
          <span class="card-writing-icon" data-i18n="about_card_1_title">AI 工具</span>
          <p data-i18n="about_card_1_desc">拆解和使用 AI 创作工具，把复杂能力变成可上手的工作流。</p>
        </article>
        <article class="card card-writing">
          <span class="card-writing-icon" data-i18n="about_card_2_title">产品思考</span>
          <p data-i18n="about_card_2_desc">从 builder 视角写产品设计和创作者经济，关注"好用"而非"炫技"。</p>
        </article>
        <article class="card card-writing">
          <span class="card-writing-icon" data-i18n="about_card_3_title">工程实践</span>
          <p data-i18n="about_card_3_desc">前端、工作流自动化、部署和发布流程中踩过的坑和解法。</p>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>
