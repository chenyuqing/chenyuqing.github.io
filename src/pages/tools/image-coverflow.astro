---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="图片流览 · 工具" description="在浏览器本地以 Coverflow 浏览图片文件夹。">
  <main id="content" class="coverflow-page">
    <section class="shell coverflow-top">
      <a class="tool-back" href="/tools/"><span class="lang-zh">← 返回工具箱</span><span class="lang-en">← Back to Tools</span></a>
      <p class="tool-eyebrow"><span class="lang-zh">图片工具</span><span class="lang-en">Image Utility</span></p>
      <h1><span class="lang-zh">图片流览</span><span class="lang-en">Image Coverflow</span></h1>
      <p class="tool-lead"><span class="lang-zh">选择一个图片文件夹，在浏览器本地浏览。不会上传、保存或处理视频。</span><span class="lang-en">Choose an image folder to browse locally. Nothing is uploaded, saved, or processed as video.</span></p>
    </section>

    <section class="shell coverflow-panel">
      <div class="folder-picker" id="folder-picker">
        <input id="folder-input" type="file" accept="image/*" webkitdirectory multiple />
        <label for="folder-input">
          <strong><span class="lang-zh">选择图片文件夹</span><span class="lang-en">Choose image folder</span></strong>
          <span><span class="lang-zh">支持 JPG、PNG、WebP、GIF、AVIF 等图片格式</span><span class="lang-en">JPG, PNG, WebP, GIF, AVIF, and other image formats</span></span>
        </label>
      </div>

      <div class="gallery" id="gallery" hidden>
        <div class="gallery-bar">
          <p id="gallery-status" aria-live="polite"></p>
          <button class="clear-btn" id="clear-images" type="button"><span class="lang-zh">更换文件夹</span><span class="lang-en">Change folder</span></button>
        </div>
        <div class="coverflow-stage" id="coverflow-stage" tabindex="0" aria-label="Image Coverflow">
          <button class="gallery-arrow gallery-prev" type="button" id="previous-image" aria-label="Previous image">←</button>
          <div class="coverflow-cards" id="coverflow-cards"></div>
          <button class="gallery-arrow gallery-next" type="button" id="next-image" aria-label="Next image">→</button>
        </div>
        <div class="image-info">
          <p id="image-name"></p>
          <p id="image-count"></p>
        </div>
        <p class="gallery-hint"><span class="lang-zh">点击图片切换，点击中间图片放大。也可使用 ← → 方向键。</span><span class="lang-en">Click an image to navigate. Click the centered image to enlarge it. Arrow keys work too.</span></p>
      </div>

      <p class="empty-note" id="empty-note"><span class="lang-zh">文件夹内容只会在此浏览器标签中读取；关闭或更换文件夹后，临时图片引用会被释放。</span><span class="lang-en">Folder contents are read only in this browser tab. Temporary image references are released when you close or replace it.</span></p>
    </section>
  </main>

  <dialog class="image-dialog" id="image-dialog">
    <button class="dialog-close" id="close-preview" type="button" aria-label="Close preview">×</button>
    <img id="preview-image" alt="" />
    <p id="preview-name"></p>
  </dialog>

  <style>
    .coverflow-page { min-height: 100dvh; padding: 6.2rem 0 4.5rem; background: #11100d; color: #eee4cc; }
    .coverflow-top { margin-bottom: 1.2rem; }
    .tool-back { display: inline-flex; margin-bottom: 1.1rem; color: #d1a843; text-decoration: none; font: 700 .78rem/1 var(--font-body); letter-spacing: .06em; }
    .tool-back:hover { color: #f0cf76; }
    .tool-eyebrow { margin: 0 0 .5rem; color: #b69a61; font: 700 .72rem/1.3 var(--font-body); letter-spacing: .12em; text-transform: uppercase; }
    .coverflow-top h1 { margin: 0 0 .65rem; color: #f4e8cb; font-size: clamp(2rem, 3.6vw, 2.8rem); line-height: 1; }
    .tool-lead { margin: 0; color: #c9bda2; line-height: 1.65; }
    .coverflow-panel { border: 1px solid rgba(240,223,179,.22); border-radius: 10px; background: #1b1914; padding: 1.25rem; }
    .folder-picker { position: relative; display: grid; min-height: 14rem; place-items: center; border: 1px dashed rgba(240,223,179,.38); border-radius: 8px; background: radial-gradient(circle at 50% 15%, rgba(209,168,67,.15), transparent 45%), #15130f; text-align: center; }
    .folder-picker input { position: absolute; width: 1px; height: 1px; opacity: 0; }
    .folder-picker label { display: grid; gap: .65rem; max-width: 26rem; padding: 2rem; color: #c9bda2; cursor: pointer; line-height: 1.55; }
    .folder-picker strong { color: #191409; background: #d1a843; padding: .85rem 1.25rem; border-radius: 7px; font: 800 .9rem/1 var(--font-body); letter-spacing: .04em; }
    .folder-picker:hover { border-color: #d1a843; }
    .gallery-bar, .image-info { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .gallery-bar { margin-bottom: .75rem; }
    .gallery-bar p, .image-info p { margin: 0; }
    .gallery-bar p { color: #b69a61; font: 700 .78rem/1.4 var(--font-body); letter-spacing: .06em; }
    .clear-btn { border: 1px solid rgba(240,223,179,.24); border-radius: 7px; background: transparent; color: #e8dcc0; padding: .6rem .8rem; font: 700 .75rem/1 var(--font-body); cursor: pointer; }
    .clear-btn:hover { border-color: #d1a843; color: #f0cf76; }
    .coverflow-stage { position: relative; height: clamp(22rem, 56vw, 34rem); overflow: hidden; border: 1px solid rgba(240,223,179,.18); border-radius: 8px; background: radial-gradient(ellipse at center, #342b1d, #100f0c 68%); outline: none; }
    .coverflow-stage:focus-visible { box-shadow: 0 0 0 2px #d1a843; }
    .coverflow-cards { position: absolute; inset: 0; isolation: isolate; }
    .cover-card { position: absolute; top: 50%; left: 50%; width: min(62vw, 35rem); height: min(43vw, 26rem); max-height: 78%; border: 0; border-radius: 6px; padding: 0; overflow: hidden; background: #252117; box-shadow: 0 18px 50px rgba(0,0,0,.55); cursor: pointer; transform-origin: center; transition: transform .38s cubic-bezier(.2,.8,.2,1), opacity .3s ease, filter .3s ease; }
    .cover-card img { width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none; user-select: none; }
    .cover-card::after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(255,255,255,.1); border-radius: inherit; pointer-events: none; }
    .gallery-arrow { position: absolute; top: 50%; z-index: 20; width: 3rem; height: 3rem; border: 1px solid rgba(240,223,179,.35); border-radius: 50%; background: rgba(17,16,13,.85); color: #f0cf76; font-size: 1.4rem; cursor: pointer; transform: translateY(-50%); }
    .gallery-arrow:hover { border-color: #d1a843; background: #242015; }
    .gallery-prev { left: 1rem; }.gallery-next { right: 1rem; }
    .image-info { padding: .85rem .2rem 0; color: #f0e2c0; font: .85rem/1.4 var(--font-mono); }
    #image-count { color: #9d8f72; white-space: nowrap; }.gallery-hint, .empty-note { margin: .7rem 0 0; color: #9d8f72; font-size: .8rem; line-height: 1.55; }.empty-note { text-align: center; }
    .image-dialog { width: min(92vw, 75rem); max-height: 92dvh; border: 1px solid rgba(240,223,179,.35); border-radius: 8px; background: #11100d; color: #eee4cc; padding: 1.2rem; }.image-dialog::backdrop { background: rgba(0,0,0,.8); }.image-dialog img { display: block; max-width: 100%; max-height: calc(92dvh - 5rem); margin: 0 auto; object-fit: contain; }.image-dialog p { margin: .75rem 2.5rem 0 0; color: #c9bda2; font: .78rem/1.3 var(--font-mono); overflow-wrap: anywhere; }.dialog-close { position: absolute; top: .6rem; right: .7rem; border: 0; background: transparent; color: #f0cf76; font-size: 2rem; cursor: pointer; }
    .lang-en { display: none; }:global(html[data-lang='en']) .lang-zh { display: none; }:global(html[data-lang='en']) .lang-en { display: inline; }
    @media (max-width: 720px) { .coverflow-page { padding: 4.4rem 0 3rem; }.coverflow-panel { padding: .8rem; }.coverflow-stage { height: 23rem; }.cover-card { width: 15.5rem; height: 20rem; }.gallery-arrow { width: 2.5rem; height: 2.5rem; }.gallery-prev { left: .45rem; }.gallery-next { right: .45rem; } }
  </style>

  <script>
    const root = document.documentElement;
    const input = document.getElementById('folder-input');
    const picker = document.getElementById('folder-picker');
    const gallery = document.getElementById('gallery');
    const emptyNote = document.getElementById('empty-note');
    const cards = document.getElementById('coverflow-cards');
    const stage = document.getElementById('coverflow-stage');
    const status = document.getElementById('gallery-status');
    const name = document.getElementById('image-name');
    const count = document.getElementById('image-count');
    const dialog = document.getElementById('image-dialog');
    const preview = document.getElementById('preview-image');
    const previewName = document.getElementById('preview-name');
    let images = [];
    let active = 0;
    const isEn = () => root.getAttribute('data-lang') === 'en';
    const text = (zh, en) => isEn() ? en : zh;
    const isImage = (file) => file.type.startsWith('image/') || /\.(avif|bmp|gif|heic|jpe?g|png|svg|webp)$/i.test(file.name);
    const relative = (index) => {
      let value = (index - active) % images.length;
      if (value > images.length / 2) value -= images.length;
      if (value < -images.length / 2) value += images.length;
      return value;
    };
    const releaseImages = () => images.forEach((image) => URL.revokeObjectURL(image.url));
    const render = () => {
      cards.replaceChildren();
      images.forEach((image, index) => {
        const rel = relative(index);
        if (Math.abs(rel) > 3) return;
        const card = document.createElement('button');
        const scale = rel === 0 ? 1 : Math.max(.52, .78 - Math.abs(rel) * .09);
        const shift = rel * (rel === 0 ? 0 : 31 + Math.max(0, Math.abs(rel) - 1) * 13);
        card.className = 'cover-card';
        card.style.zIndex = String(10 - Math.abs(rel));
        card.style.opacity = String(Math.max(0, 1 - Math.max(0, Math.abs(rel) - 2) * .48));
        card.style.filter = rel === 0 ? 'none' : 'brightness(.62) saturate(.72)';
        card.style.transform = `translate(-50%, -50%) translateX(${shift}%) scale(${scale}) perspective(900px) rotateY(${Math.max(-44, Math.min(44, -rel * 17))}deg)`;
        card.ariaLabel = image.name;
        const img = document.createElement('img');
        img.src = image.url;
        img.alt = image.name;
        card.append(img);
        card.addEventListener('click', () => index === active ? openPreview() : select(index));
        cards.append(card);
      });
      const current = images[active];
      name.textContent = current?.name || '';
      count.textContent = text(`${active + 1} / ${images.length}`, `${active + 1} / ${images.length}`);
    };
    const select = (index) => { active = (index + images.length) % images.length; render(); };
    const openPreview = () => { const image = images[active]; if (!image) return; preview.src = image.url; preview.alt = image.name; previewName.textContent = image.name; dialog.showModal(); };
    input.addEventListener('change', () => {
      releaseImages();
      const files = [...input.files].filter(isImage).sort((a, b) => (a.webkitRelativePath || a.name).localeCompare(b.webkitRelativePath || b.name, undefined, { numeric: true }));
      images = files.map((file) => ({ name: file.webkitRelativePath || file.name, url: URL.createObjectURL(file) }));
      active = 0;
      if (!images.length) { gallery.hidden = true; picker.hidden = false; emptyNote.hidden = false; status.textContent = ''; return; }
      picker.hidden = true; emptyNote.hidden = true; gallery.hidden = false;
      status.textContent = text(`已载入 ${images.length} 张本地图片`, `${images.length} local images loaded`);
      render(); stage.focus();
    });
    document.getElementById('previous-image').addEventListener('click', () => select(active - 1));
    document.getElementById('next-image').addEventListener('click', () => select(active + 1));
    document.getElementById('clear-images').addEventListener('click', () => { releaseImages(); images = []; active = 0; input.value = ''; cards.replaceChildren(); gallery.hidden = true; picker.hidden = false; emptyNote.hidden = false; });
    document.getElementById('close-preview').addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
    window.addEventListener('keydown', (event) => { if (dialog.open || !images.length) return; if (event.key === 'ArrowLeft') { event.preventDefault(); select(active - 1); } if (event.key === 'ArrowRight') { event.preventDefault(); select(active + 1); } });
    window.addEventListener('beforeunload', releaseImages);
    const applyMeta = () => { document.title = text('图片流览 · 工具', 'Image Coverflow · Tools'); document.querySelector('meta[name="description"]')?.setAttribute('content', text('在浏览器本地以 Coverflow 浏览图片文件夹。', 'Browse an image folder locally with Coverflow.')); };
    applyMeta(); new MutationObserver(applyMeta).observe(root, { attributes: true, attributeFilter: ['data-lang'] });
  </script>
</BaseLayout>
